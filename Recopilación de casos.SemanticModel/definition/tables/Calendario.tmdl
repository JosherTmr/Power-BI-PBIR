		sourceColumn: [Nombre Día]

		annotation SummarizationSetBy = Automatic

	partition Calendario = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR ( DATE ( 2019, 1, 1 ), DATE ( 2027, 12, 31 ) ), // <-- AJUSTA ESTAS FECHAS MIN y MAX para cubrir todo tu rango
				    "Año", YEAR ( [Date] ),
				    "Mes Num", MONTH ( [Date] ),
				    "Mes Nombre", FORMAT ( [Date], "MMMM", "es-ES" ),
				    "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				    "AñoMes", FORMAT ( [Date], "YYYY-MM" ),
				    "Semana Año", WEEKNUM ( [Date], 1 ), // Lunes como inicio de semana
				    "Día Semana", WEEKDAY ( [Date], 2 ), // 1=Lunes, 7=Domingo
				    "Nombre Día", FORMAT ( [Date], "dddd", "es-ES" )
				    // Puedes añadir más columnas útiles (festivos, etc.)
				)

	annotation PBI_Id = 4baa22569ba7435b88093b9e03718c17

