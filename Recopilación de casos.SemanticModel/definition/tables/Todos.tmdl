table Todos
	lineageTag: 3cdd3fa4-c147-45fd-a4bd-43a8c1189615

	measure TotalCasesDividedByResolved =
			
			VAR TotalCases = COUNTROWS('Todos')
			VAR ResolvedCases =
			    CALCULATE(
			        COUNTROWS('Todos'),
			        'Todos'[Status] = "Solucionado" || 'Todos'[Status] = "Cerrado" || 'Todos'[Status] = "Cancelado"
			    )
			RETURN
			    DIVIDE(ResolvedCases, TotalCases,  0)
		lineageTag: c9bad072-2ca8-4a4c-bd4b-69cc99f7efb0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure PorcentajeProgress = DIVIDE(MAX(Todos[Progress]),100)
		lineageTag: 2e604998-1ad7-4aba-aae8-e0da23126f6f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Tiempo_100_HHMMSS = ```
			
			VAR TiempoTotal = DIVIDE(SELECTEDVALUE(Todos[Time elapsed]), SELECTEDVALUE(Todos[Progress]), 0) * 100
			VAR Horas = INT(TiempoTotal / 60)
			VAR Minutos = INT(MOD(TiempoTotal, 60))
			VAR Segundos = ROUND((TiempoTotal - INT(TiempoTotal)) * 60, 0)
			
			RETURN 
			FORMAT(Horas, "00") & ":" & FORMAT(Minutos, "00") & ":" & FORMAT(Segundos, "00")
			
			
			```
		lineageTag: 40a7f0de-887d-43e1-9618-e34fb38e8a44

	measure ElapsedTimeFormatted = ```
			
			VAR TotalMinutes = Max(Todos[Time elapsed])
			VAR Hours = INT(TotalMinutes / 60)
			VAR Minutes = INT(MOD(TotalMinutes, 60))
			VAR Seconds = ROUND((MOD(TotalMinutes, 1) * 60), 0)
			RETURN
			FORMAT(Hours, "00") & ":" & FORMAT(Minutes, "00") & ":" & FORMAT(Seconds, "00")
			
			```
		lineageTag: 46c485cb-4b3b-4631-a1b0-a43f6d0db91d

	measure 'Service Calls Count' = ```
			
			CALCULATE (
			    DISTINCTCOUNT ( Todos[Composite id] ),
			    Todos[Service Name] = "Service Call"
			)
			
			```
		formatString: 0
		lineageTag: 53c3b491-8616-452d-82dc-467d53816f6a

	measure 'Incidents Count' =
			
			CALCULATE (
			    DISTINCTCOUNT ( Todos[Composite id] ),
			    Todos[Service Name] = "Incident"
			)
		formatString: 0
		lineageTag: de151c5f-da5f-4bcf-aaea-18d169c09b8a

