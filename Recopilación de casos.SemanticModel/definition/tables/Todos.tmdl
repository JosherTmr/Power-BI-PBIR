				    #"Tipo cambiado" = Table.TransformColumnTypes(#"Se expandió Transformar archivo",{{"Name", type text}, {"Number Case", Int64.Type}, {"Composite id", type text}, {"Subject", type text}, {"Registration date", type datetime}, {"Status", type text}, {"Client", type text}, {"Category", type text}, {"Service", type text}, {"Responsable Name", type text}, {"Author", type text}, {"Reason", type text}, {"Impact", type text}, {"Urgency", type text}, {"PriorityName", type text}, {"Group Name", type text}, {"Company", type text}, {"CI", type any}, {"RegistryType", type text}, {"Estimated Date of Solution", type datetime}, {"Estimated Date of Attention", type datetime}, {"Hierarchy", type text}, {"Department", type text}, {"Floor", type any}, {"City", type text}, {"Country", type text}, {"Headquarters", type text}, {"Building", type any}, {"Time elapsed", Int64.Type}, {"Progress", Int64.Type}}),
				    #"Filas ordenadas1" = Table.Buffer(Table.Sort(#"Tipo cambiado",{{"Registration date", Order.Ascending}, {"Date modified", Order.Descending}})),
				    #"Duplicados quitados" = Table.Distinct(#"Filas ordenadas1", {"Composite id"}),
				    #"Columnas quitadas1" = Table.RemoveColumns(#"Duplicados quitados",{"Name", "Date modified", "Reason", "Company", "CI", "Country", "Headquarters", "Building"}),
				    #"Personalizada agregada" = Table.AddColumn(#"Columnas quitadas1", "Service Name", each if [Service] = "INC_Power BI" then "Incident" else "Service Call", type text),
				    #"Personalizada agregada1" = Table.AddColumn(#"Personalizada agregada", "Personalizado", each Date.WeekOfYear(DateTime.Date([Registration date]))),
				    #"Tipo cambiado1" = Table.TransformColumnTypes(#"Personalizada agregada1",{{"Personalizado", Int64.Type}}),
				    #"Personalizada agregada2" = Table.AddColumn(#"Tipo cambiado1", "Supercategoria", each let cat = [Category] in
				    if List.Contains({"Modificación de accesos", "Crear usuario", "Inactivar usuario", "INC_Error de acceso"}, cat) then "Gestión de Accesos y Usuarios"
				    else if List.Contains({"Generar reporte"}, cat) then "Nuevos Requerimientos y Desarrollos"
				    else if List.Contains({"INC_Calculos en reportes", "INC_Carga de información data erroneo", "INC_Carga de información duplicada"}, cat) then "Inconsistencias y Calidad de Datos"
				    else if List.Contains({"INC_Carga de información error en fuente de datos", "INC_Carga de información error en comunicación", "INC_Alertamiento", "INC_Objetos error de configuración"}, cat) then "Ingeniería y Flujos de Datos"
				    else if List.Contains({"Capacitación de reportes/herramienta", "Configuración", "Instalación de prerrequisitos"}, cat) then "Soporte y Capacitación"
				    else if List.Contains({"Evento de Seguridad"}, cat) then "Seguridad"
				    else "Otras Categorías"),
				    #"Fecha insertada" = Table.AddColumn(#"Personalizada agregada2", "Fecha", each Date.From([Registration date]), type date)
				in
				    #"Fecha insertada"

